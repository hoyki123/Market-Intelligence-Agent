# Copy this file to .env and fill in your keys
# cp .env.example .env

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "anthropic" (recommended) or "openai"
LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com   # or your proxy URL
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1      # or your proxy URL
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1

# ── Market Data (optional but recommended) ────────────────────────────────────
# Finnhub — news & sentiment fallback (free tier at finnhub.io)
FINNHUB_API_KEY=

# Massive.com — real-time price, news, company overview (paid)
MASSIVE_API_KEY=

# Alpha Vantage — additional market data (free tier at alphavantage.co)
ALPHA_VANTAGE_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, zero setup — leave the lines below blank):
DATABASE_URL=sqlite:///warren_brain.db

# Supabase / PostgreSQL — paste the raw password, quote_plus encodes it automatically:
DB_HOST=db.[PROJECT-REF].supabase.co
DB_USER=postgres
DB_PASSWORD=your-raw-password-here
DB_NAME=postgres
DB_PORT=5432

# ── Agent Weights ─────────────────────────────────────────────────────────────
# Must sum to 1.0
WEIGHT_FUNDAMENTALS=0.30
WEIGHT_TECHNICALS=0.20
WEIGHT_SENTIMENT=0.15
WEIGHT_THIRTEEN_F=0.15
WEIGHT_ONTOLOGY=0.10
WEIGHT_RISK=0.10
